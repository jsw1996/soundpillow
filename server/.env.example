# Server Environment Variables

# Required: OpenRouter API key for mood message generation
OPENROUTER_API_KEY="your-openrouter-api-key"

# Server port (default: 3001)
PORT=3001

# CORS origins — comma-separated (default: http://localhost:3000)
CORS_ORIGINS="http://localhost:3000"

# Public asset base URL — use Azure Front Door CDN endpoint for cached delivery
ASSET_BASE_URL="https://<cdn-endpoint>.azurefd.net/<container>"
