# Server Environment Variables

# Required: OpenRouter API key for LLM story generation
OPENROUTER_API_KEY="your-openrouter-api-key"

# Server port (default: 3001)
PORT=3001

# Daily pre-generation schedule in cron syntax (default: 8:00 PM UTC, generates next UTC day)
CRON_SCHEDULE="0 20 * * *"
# Azure App Service reminder:
# - Free (F1) plans do not support Always On, so in-process cron can miss runs after idle/sleep.
# - Upgrade the Linux App Service Plan to B1 or higher, then enable Always On in the Azure portal.
# - Southeast Asia Linux B1 was about USD 0.02/hour when this note was added on 2026-03-06.

# Locales to pre-generate stories for (default: en,zh,ja,es)
LOCALES="en,zh,ja,es"

# CORS origins — comma-separated (default: http://localhost:3000)
CORS_ORIGINS="http://localhost:3000"

# Optional: Bearer token to protect the POST /api/stories/generate endpoint
ADMIN_TOKEN=""

# Optional: Custom data directory for story JSON files
# DATA_DIR="data/stories"

# Azure Speech Services (for TTS narration)
AZURE_SPEECH_KEY="your-azure-speech-key"
AZURE_SPEECH_REGION="southeastasia"
